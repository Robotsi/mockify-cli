{
  "name": "mockify",
  "version": "1.0.0",
  "description": "Minimalist and lightning-fast local Mock API server powered by Bun",
  "main": "src/cli.ts",
  "type": "module",
  "bin": {
    "mockify": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts start",
    "build": "bun build src/cli.ts --outdir ./dist --target node",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}